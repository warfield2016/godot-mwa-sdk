<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto Backup and device transfer exclusion rules (API 31+, Android 12+).
    Prevents EncryptedSharedPreferences (auth tokens) from being included in
    cloud backups or device-to-device transfers.

    HOST APP: Reference this in your manifest with:
        android:dataExtractionRules="@xml/data_extraction_rules"
    Or merge these exclusions into your own data_extraction_rules.xml.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="solana_mwa_auth_prefs.xml" />
        <exclude domain="sharedpref" path="solana_mwa_auth_prefs.xml.bak" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="solana_mwa_auth_prefs.xml" />
        <exclude domain="sharedpref" path="solana_mwa_auth_prefs.xml.bak" />
    </device-transfer>
</data-extraction-rules>
